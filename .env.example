# ─── Database ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=bank_user
DB_PASSWORD=bank_password

# ─── Redis ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=replace-with-a-256-bit-base64-secret
JWT_EXPIRATION=86400000
JWT_ALLOW_DEFAULT_SECRET=false

# ─── CORS ───────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Rate Limiting ──────────────────────────────────────
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_TIME_WINDOW_MS=10000

# ─── Failed Login ───────────────────────────────────────
FAILED_LOGIN_BACKEND=redis
FAILED_LOGIN_MAX_ATTEMPTS=5
FAILED_LOGIN_WINDOW_MINUTES=15

# ─── Transfer ───────────────────────────────────────────
TRANSFER_CANCELLATION_WINDOW_HOURS=24

# ─── Idempotency ────────────────────────────────────────
IDEMPOTENCY_CLEANUP_CRON=0 0 * * * *
IDEMPOTENCY_EXPIRATION_HOURS=24

# ─── Outbox ─────────────────────────────────────────────
OUTBOX_POLL_DELAY_MS=2000
OUTBOX_MAX_RETRIES=5
OUTBOX_USE_SKIP_LOCKED=true

# ─── Tracing (OpenTelemetry) ────────────────────────────
TRACING_SAMPLE_RATE=0.1
OTLP_ENDPOINT=http://localhost:4318/v1/traces
